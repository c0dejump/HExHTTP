# ═══════════════════════════════════════════════════════════
# HEADERS MULTI-VALEURS EDGE CASES
# ═══════════════════════════════════════════════════════════
{"Accept-Language": "en-US,en;q=0.9" * 100},
{"Accept-Encoding": ",,,,,gzip,,,,,"},
{"Cookie": ";" * 1000},
{"Set-Cookie": "\r\n" * 100},

# ═══════════════════════════════════════════════════════════
# HEADERS AVEC CARACTÈRES SPÉCIAUX PROBLÉMATIQUES
# ═══════════════════════════════════════════════════════════
{"X-Test-CRLF": "value\r\nInjected: header"},
{"X-Test-NULL": "value\x00poisoned"},
{"X-Test-Unicode-Null": "value\u0000poisoned"},
{"X-Test-BOM": "\ufeffvalue"},
{"X-Test-RTL": "\u202evalue"},
{"X-Test-ZWNJ": "val\u200cue"},
{"X-Test-Zero-Width-Space": "val\u200bue"},

# ═══════════════════════════════════════════════════════════
# HEADERS DE SECURITÉ MALFORMÉS
# ═══════════════════════════════════════════════════════════
{"Content-Security-Policy": "default-src 'none'" * 100},
{"X-XSS-Protection": "1; mode=block" * 50},
{"X-Content-Type-Options": "nosniff" * 50},
{"Referrer-Policy": "no-referrer" * 50},
{"Feature-Policy": ("geolocation 'none'; " * 100)},

# ═══════════════════════════════════════════════════════════
