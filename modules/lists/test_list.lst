    # ===================================================================
    {"X-Forwarded-Scheme": "http"},
    {"X-Forwarded-Port": "80"},
    {"X-Forwarded-Proto": "http", "X-Forwarded-Port": "80"},
    {"X-Original-URL": "/path"},
    {"X-Forwarded-Prefix": "/nonexistent"},

